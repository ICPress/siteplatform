@model PageModel
@using siteplatform.Util
@inject Microsoft.Extensions.Options.IOptions<ServerSettings> ServerSettingsOptions
@{
    var cfg      = ServerSettingsOptions.Value;
    var smallCDN = cfg.CDNRequestSmallPath;
    var bigCDN   = cfg.CDNRequestLargePath;

    var isQuery   = Model?.Query != null;
    var pageTitle = isQuery ? "Search: " + Model?.Query : "Browse Articles";
    ViewData["Title"] = pageTitle;

    List<StoryPublishedModel>? articles = Model?.Stories ?? new List<StoryPublishedModel>();
    var linkBase = LinkUtil.GetLinkPathFromModel(Model);
}

<section class="page-header">
    <div class="container">
        <h1 class="page-title">@pageTitle</h1>
        @if (!isQuery)
        {
            <p class="page-subtitle">Explore all articles &mdash; Page @Model?.CurrentPage</p>
        }
        else
        {
            <p class="page-subtitle">Articles tagged or authored: <strong>@Model?.Query</strong></p>
        }
    </div>
</section>

<section class="articles-section">
    <div class="container articles-container">
        <div class="articles-main">
            <h2 class="section-title">Articles</h2>
            <div class="article-list">
                @if (articles.Any())
                {
                    var cardIndex = 0;
                    foreach (var article in articles)
                    {
                        var title      = (!string.IsNullOrEmpty(article.StoryTitle)) ? article.StoryTitle : article.EmptyTitle;
                        var miniUrl    = LinkUtil.GetMiniatureUrl(article.StylingInfo?.TitleBackgroundImage, bigCDN, smallCDN);
                        var category   = article.Category;
                        DateTime? ts   = null;
                        if (!string.IsNullOrEmpty(article.Timestamp))
                            ts = DateTime.Parse(article.Timestamp, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.AssumeUniversal).ToUniversalTime();

                        <article class="article-card @(miniUrl != null ? "has-image" : "no-image")" onclick="location.href='/s/@article.SlugTitle'">
                            @if (miniUrl != null)
                            {
                                <a href="/s/@article.SlugTitle" class="article-image-link">
                                    <img src="@miniUrl" alt="@title"
                                         fetchpriority="@(cardIndex == 0 ? "high" : "auto")"
                                         loading="@(cardIndex < 2 ? "eager" : "lazy")"
                                         decoding="async">
                                </a>
                            }
                            <div class="article-content">
                                @if (category != null)
                                {
                                    <a href="/q/@category" class="article-category">@category</a>
                                }
                                <h3 class="article-title">
                                    <a href="/s/@article.SlugTitle" class="article-title-link">@title</a>
                                </h3>
                                @if (!string.IsNullOrEmpty(article.ContentText))
                                {
                                    <a href="/s/@article.SlugTitle" class="article-excerpt-link">
                                        <p class="article-excerpt">@(article.ContentText.Length > 160 ? article.ContentText.Substring(0, 160) + "…" : article.ContentText)</p>
                                    </a>
                                }
                                <div class="article-meta">
                                    <a href="/q/u/@article.AuthorName" class="article-author-link">
                                        @if (!string.IsNullOrEmpty(article.AuthorBadge))
                                        {
                                            var pIconUrl = LinkUtil.GetDefaultImageLinkFromImageInfoMetadata(article.AuthorBadge, bigCDN, smallCDN);
                                            <div class="article-author-badge" style="background-image:url('@pIconUrl');"></div>
                                        }
                                        else
                                        {
                                            <div class="article-author-avatar"><i class="fas fa-user-secret"></i></div>
                                        }
                                    </a>
                                    <a href="/q/u/@article.AuthorName" class="article-author-name-link">@article.AuthorName</a>
                                    @if (ts.HasValue)
                                    {
                                        <span class="article-date"><i class="fas fa-clock"></i> @DateUtil.GetTimeAgoString(ts.Value)</span>
                                    }
                                    <div class="article-stats">
                                        <div class="article-likes"><i class="fas fa-heart"></i> @article.Hearts</div>
                                    </div>
                                </div>
                            </div>
                        </article>
                        cardIndex++;
                    }
                }
                else
                {
                    <div style="text-align:center; padding: 60px 0; color: var(--text-secondary);">
                        <i class="fas fa-search" style="font-size: 3rem; margin-bottom: 20px; color: var(--accent-color); display:block;"></i>
                        <p>No articles found. Try a different search.</p>
                    </div>
                }
            </div>

            @if (Model != null && Model.PageRange?.Any() == true)
            {
                <nav class="pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <a href="@linkBase/@(Model.CurrentPage - 1)"><i class="fas fa-chevron-left"></i></a>
                    }
                    @foreach (var pg in Model.PageRange)
                    {
                        <a href="@linkBase/@pg" class="@(pg == Model.CurrentPage ? "active" : "")">@pg</a>
                    }
                    @if (articles.Count >= Model.RequestedStoryCount)
                    {
                        <a href="@linkBase/@(Model.CurrentPage + 1)"><i class="fas fa-chevron-right"></i></a>
                    }
                </nav>
            }
        </div>

        <aside class="articles-sidebar">
            @if (articles.Any())
            {
                var allTags = articles
                    .Where(s => s.Tags != null)
                    .SelectMany(s => s.Tags!)
                    .GroupBy(t => t)
                    .OrderByDescending(g => g.Count())
                    .Take(12)
                    .Select(g => g.Key)
                    .ToList();
                if (allTags.Any())
                {
                    <div class="sidebar-widget">
                        <h3 class="widget-title">Tags in Results</h3>
                        <div class="tag-cloud">
                            @foreach (var tag in allTags)
                            {
                                <a href="/q/@tag" class="tag">#@tag</a>
                            }
                        </div>
                    </div>
                }
            }

            <div class="sidebar-widget">
                <h3 class="widget-title">Navigation</h3>
                <div class="trending-topics">
                    <a href="/" class="topic">Home</a>
                    <a href="/p/1" class="topic">All Articles</a>
                    @if (Model != null && Model.CurrentPage > 1)
                    {
                        <a href="@linkBase/@(Model.CurrentPage - 1)" class="topic">← Prev</a>
                    }
                    @if (articles.Count >= (Model?.RequestedStoryCount ?? 18))
                    {
                        <a href="@linkBase/@((Model?.CurrentPage ?? 1) + 1)" class="topic">Next →</a>
                    }
                </div>
            </div>
        </aside>
    </div>
</section>
